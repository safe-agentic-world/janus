{
  "gateway": {
    "listen": ":8080",
    "transport": "http",
    "concurrency_limit": 32,
    "rate_limit_per_minute": 120,
    "circuit_breaker_failures": 5,
    "circuit_breaker_cooldown_seconds": 60,
    "tls": {
      "enabled": false,
      "cert_file": "",
      "key_file": "",
      "client_ca_file": "",
      "require_mtls": false
    }
  },
  "runtime": {
    "stateless_mode": false,
    "strong_guarantee": false,
    "deployment_mode": "unmanaged"
  },
  "policy": {
    "policy_bundle_path": "../policies/mcp-gateway.example.yaml",
    "verify_signatures": false,
    "signature_path": "",
    "public_key_path": "",
    "exec_compatibility_mode": "legacy_allowlist_fallback",
    "explain_suggestions": true
  },
  "executor": {
    "sandbox_enabled": false,
    "workspace_root": "../quickstart/workspace",
    "max_output_bytes": 65536,
    "max_output_lines": 200,
    "sandbox_profile": "none"
  },
  "credentials": {
    "enabled": false,
    "secrets": []
  },
  "audit": {
    "sink": "stderr"
  },
  "telemetry": {
    "enabled": false,
    "sink": ""
  },
  "mcp": {
    "enabled": false,
    "upstream_servers": []
  },
  "upstream": {
    "routes": []
  },
  "approvals": {
    "enabled": true,
    "backend": "file",
    "store_path": "./nomos-mcp-http-approvals.json",
    "ttl_seconds": 900,
    "webhook_token": "",
    "slack_token": "",
    "teams_token": ""
  },
  "identity": {
    "principal": "system",
    "agent": "nomos",
    "environment": "dev",
    "api_keys": {
      "dev-api-key": "developer@example.com"
    },
    "agent_secrets": {
      "nomos": "dev-agent-secret"
    },
    "oidc": {
      "enabled": false,
      "issuer": "",
      "audience": "",
      "public_key_path": ""
    },
    "spiffe": {
      "enabled": false,
      "trust_domain": ""
    }
  },
  "redaction": {
    "patterns": []
  }
}
